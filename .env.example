# Backend
DATABASE_URL=postgresql://...
SECRET_KEY=replace-with-a-long-random-value
CORS_ORIGINS=https://valorbuddy.com,https://www.valorbuddy.com
GOOGLE_API_KEY=replace-with-google-api-key
# Optional backward-compatible alias; do not set both unless desired.
# GEMINI_API_KEY=replace-with-the-same-google-api-key
GEMINI_MODEL=gemini-3.6-flash
# Optional. If omitted, the planner uses GEMINI_MODEL automatically.
GEMINI_PLANNER_MODEL=gemini-3.6-flash
ENABLE_GOOGLE_SEARCH_GROUNDING=true
GOOGLE_PLACES_API_KEY=replace-with-google-maps-key
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global

# Frontend
VITE_API_BASE_URL=https://valorbuddy.onrender.com
