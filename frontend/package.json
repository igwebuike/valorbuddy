{
  "name": "valorbuddy-enterprise-frontend",
  "version": "3.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "node ./node_modules/vite/bin/vite.js build",
