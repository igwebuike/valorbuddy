    "@capacitor/geolocation": "^7.1.5",
    "@capacitor/local-notifications": "^7.0.3",
    "@capacitor/preferences": "^7.0.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.4.3",
    "@capacitor/android": "^7.4.3",
    "@capacitor/ios": "^7.4.3"
  }
}
